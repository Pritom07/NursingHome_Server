model Speciality{
    id String @id @default(uuid())
    title String
    description String?
    icon String?
    isDeleted Boolean @default(false)
    deletedAt DateTime?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    doctorSpecialities DoctorSpeciality[]

    @@index([id])
    @@index([title])
    @@map("speciality")
}