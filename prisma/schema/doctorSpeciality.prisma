model DoctorSpeciality{
    id String @id @default(uuid())

    doctor Doctor @relation(fields: [doctor_id],references: [id],onDelete: Cascade,onUpdate: Cascade)
    doctor_id String

    speciality Speciality @relation(fields: [speciality_id],references: [id],onDelete: Cascade,onUpdate: Cascade)
    speciality_id String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([id])
    @@index([doctor_id])
    @@index([speciality_id])
    @@map("doctorSpeciality")
}